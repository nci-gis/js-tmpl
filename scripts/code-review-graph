#!/usr/bin/env bash
#
# Wrapper around `code-review-graph` (https://github.com/tirth8205/code-review-graph).
#
# Usage:
#   scripts/code-review-graph setup            Install into repo-root .venv via uv.
#   scripts/code-review-graph setup --upgrade  Reinstall / upgrade in-place.
#   scripts/code-review-graph <any-crg-args>   Forwarded to the installed CLI.
#
# The venv lives at <repo-root>/.venv and is git-ignored.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_DIR="$REPO_ROOT/.venv"
BIN="$VENV_DIR/bin/code-review-graph"

die() { printf 'error: %s\n' "$*" >&2; exit 1; }

require_uv() {
  command -v uv >/dev/null 2>&1 \
    || die "'uv' is not installed — see https://docs.astral.sh/uv/getting-started/installation/"
}

cmd_setup() {
  require_uv
  local upgrade=0
  for arg in "$@"; do
    case "$arg" in
      --upgrade|-U) upgrade=1 ;;
      -h|--help)
        sed -n '3,12p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
        return 0 ;;
      *) die "unknown setup flag: $arg" ;;
    esac
  done

  if [[ ! -d "$VENV_DIR" ]]; then
    echo "==> creating venv at $VENV_DIR (python >=3.10)"
    uv venv "$VENV_DIR" --python '>=3.10'
  else
    echo "==> reusing venv at $VENV_DIR"
  fi

  local pip_args=(pip install --python "$VENV_DIR/bin/python" code-review-graph)
  (( upgrade )) && pip_args+=(--upgrade)

  echo "==> installing code-review-graph"
  uv "${pip_args[@]}"

  [[ -x "$BIN" ]] || die "install completed but $BIN is missing"
  echo "==> done: $("$BIN" --version 2>/dev/null || echo "$BIN")"
}

main() {
  if [[ $# -gt 0 && "$1" == "setup" ]]; then
    shift
    cmd_setup "$@"
    return
  fi

  [[ -x "$BIN" ]] \
    || die "code-review-graph not installed — run: $(basename "$0") setup"
  exec "$BIN" "$@"
}

main "$@"
